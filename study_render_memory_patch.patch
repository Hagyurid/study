+def _slide_render_path(source_id: str, page: int = 1, zoom: float = 2.0) -> str:
+    safe_source = quote(str(source_id or "").strip())
+    page = max(1, int(page or 1))
+    zoom = min(4.0, max(0.5, float(zoom or 2.0)))
+    return f"/slides/render.png?source_id={safe_source}&page={page}&zoom={zoom:g}"
+
+
+def _get_slide_render_target(source_id: str, page: int = 1, zoom: float = 2.0) -> Tuple[Dict[str, Any], Path, int, float]:
+    source = get_source(source_id)
+    if not source:
+        raise HTTPException(status_code=404, detail="Source not found")
+    stored_path = Path(source.get("stored_path") or "")
+    if not stored_path.exists():
+        raise HTTPException(status_code=404, detail="Stored file not found")
+    suffix = stored_path.suffix.lower()
+    if suffix != ".pdf" and "pdf" not in (source.get("mime_type") or "").lower():
+        raise HTTPException(status_code=400, detail="Slide image rendering currently supports PDF lecture slides only")
+    page = max(1, int(page or 1))
+    zoom = min(4.0, max(0.5, float(zoom or 2.0)))
+    return source, stored_path, page, zoom
+
